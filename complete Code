def _get_total_pages(pdf_path: str) -> int:
    """Return page count of a PDF using PyMuPDF (fast, no rendering)."""
    try:
        import fitz
        doc   = fitz.open(pdf_path)
        count = doc.page_count
        doc.close()
        return count
    except Exception:
        return 0


